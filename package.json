{
  "name": "cogito-work-manager",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Slack to Linear task bot powered by pi-coding-agent",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "manager:diagnostics": "tsx scripts/manager-diagnostics.ts",
    "workgraph:health": "tsx scripts/workgraph-maintenance.ts health",
    "workgraph:snapshot": "tsx scripts/workgraph-maintenance.ts snapshot",
    "workgraph:compact": "tsx scripts/workgraph-maintenance.ts compact",
    "workgraph:recover": "tsx scripts/workgraph-maintenance.ts recover"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.63.2",
    "@mariozechner/pi-coding-agent": "^0.63.2",
    "@slack/socket-mode": "^2.0.6",
    "@slack/web-api": "^7.15.0",
    "dotenv": "^17.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "tsx": "^4.20.5",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
